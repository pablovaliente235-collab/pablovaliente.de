{
  "name": "pablovaliente-de",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./pablovaliente.de/dist/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./pablovaliente.de/dist/output.css --watch",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "tailwindcss": "^3.4.0",
    "wrangler": "^4.78.0"
  }
}
